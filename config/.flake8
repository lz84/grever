# Allow for better formatting of long lines with comments
per-file-ignores = 
    __init__.py: F401
    tests/*: F401
    src/reins/__init__.py: F401
    src/reins/models.py: F401
    src/reins/manager/__init__.py: F401
    src/reins/persistence/__init__.py: F401
    src/reins/grasp/__init__.py: F401
    src/reins/api/__init__.py: F401
    src/reins/main.py: F401
    src/reins/config.py: F401
    src/reins/__init__.py: F401
    tests/*: F401
    *.py: F401