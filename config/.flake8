[flake8]
max-line-length = 88
ignore = E203, W503
exclude = 
    .git
    __pycache__
    .venv
    .tox
    .mypy_cache
    .pytest_cache
    .coverage
    htmlcov
    .env
    data/
    migrations/
    tests/
    .pre-commit-config.yaml
    pyproject.toml
    .commit-msg-config
    .gitignore
    .pre-commit-config.yaml
    .flake8
    .bandit
    .pylintrc
    .mypy.ini
    .isort.cfg
    .editorconfig
    .readthedocs.yml
    .github/
    .vscode/
    .idea/
    .DS_Store
    *.pyc
    *.pyo
    *.pyd
    *.so
    *.egg-info/
    dist/
    build/
    .coverage
    .coverage.*
    htmlcov/
    .pytest_cache/
    .mypy_cache/
    .tox/
    .venv/
    venv/
